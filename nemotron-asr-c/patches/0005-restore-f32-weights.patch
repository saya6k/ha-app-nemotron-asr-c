+typedef struct {
+    float *y;
+    const float *x;
+    const float *w;
+    const float *b;
+    int rows;
+    int in_dim;
+    int prompt_dim;
+    int prompt_id;
+    int out_dim;
+} nemo_f32_prompt_task_t;
+
+static void nemo_f32_prompt_worker(int tid, int n_threads, void *arg) {
+    nemo_f32_prompt_task_t *t = (nemo_f32_prompt_task_t *)arg;
+    int stride = t->in_dim + t->prompt_dim;
+    int start = (t->out_dim * tid) / n_threads;
+    int end = (t->out_dim * (tid + 1)) / n_threads;
+    for (int r = 0; r < t->rows; r++) {
+        const float *xr = t->x + (size_t)r * t->in_dim;
+        for (int o = start; o < end; o++) {
+            const float *wr = t->w + (size_t)o * stride;
+            float v = (t->b ? t->b[o] : 0.0f) + wr[t->in_dim + t->prompt_id];
+            v += nemo_dot_f32(xr, wr, t->in_dim);
+            t->y[(size_t)r * t->out_dim + o] = v > 0.0f ? v : 0.0f;
+        }
+    }
+}
+
+typedef struct {
+    float *y;
+    const float *x;
+    const float *h;
+    const float *w_ih;
+    const float *w_hh;
+    const float *b_ih;
+    const float *b_hh;
+    int dim;
+    int out_dim;
+} nemo_f32_lstm_task_t;
+
+static void nemo_f32_lstm_worker(int tid, int n_threads, void *arg) {
+    nemo_f32_lstm_task_t *t = (nemo_f32_lstm_task_t *)arg;
+    int start = (t->out_dim * tid) / n_threads;
+    int end = (t->out_dim * (tid + 1)) / n_threads;
+    for (int o = start; o < end; o++) {
+        float v = (t->b_ih ? t->b_ih[o] : 0.0f) + (t->b_hh ? t->b_hh[o] : 0.0f);
+        v += nemo_dot_f32(t->x, t->w_ih + (size_t)o * t->dim, t->dim);
+        v += nemo_dot_f32(t->h, t->w_hh + (size_t)o * t->dim, t->dim);
+        t->y[o] = v;
+    }
+}
+
+typedef struct {
