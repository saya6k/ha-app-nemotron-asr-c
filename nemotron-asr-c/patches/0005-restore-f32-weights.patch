+/* ---- f32 reference weight path (NEMO_TENSOR_F32) ----
+ * Restored after upstream went W8A8 Q8P-only; the add-on keeps f32 as an
+ * optional full-precision reference quant. Generic and single-threaded
+ * (accuracy reference, not a throughput path); uses the SIMD nemo_dot_f32. */
+static void nemo_f32_linear_ref(float *y, const float *x, const float *w,
+                                const float *b, int rows, int in_dim, int out_dim) {
+    for (int r = 0; r < rows; r++) {
+        const float *xr = x + (size_t)r * in_dim;
+        float *yr = y + (size_t)r * out_dim;
+        for (int o = 0; o < out_dim; o++)
+            yr[o] = nemo_dot_f32(xr, w + (size_t)o * in_dim, in_dim) + (b ? b[o] : 0.0f);
+    }
+}
