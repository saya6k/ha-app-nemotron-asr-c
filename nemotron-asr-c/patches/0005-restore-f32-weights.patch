+/* ---- f32 reference weight path (NEMO_TENSOR_F32) ----
+ * Restored after upstream went W8A8 Q8P-only; the add-on keeps f32 as an
+ * optional full-precision reference quant. The dense matvec is memory-bandwidth
+ * bound (4 B/weight), so the speedup comes from the thread pool, not wider
+ * vectors: workers split the output dimension into disjoint row ranges (no
+ * shared writes) and the inner product is already SIMD via nemo_dot_f32. */
+typedef struct {
+    float *y;
+    const float *x;
+    const float *w;
+    const float *b;
+    int rows;
+    int in_dim;
+    int out_dim;
+} nemo_f32_linear_task_t;
+
+static void nemo_f32_linear_worker(int tid, int n_threads, void *arg) {
+    nemo_f32_linear_task_t *t = (nemo_f32_linear_task_t *)arg;
+    int start = (t->out_dim * tid) / n_threads;
+    int end = (t->out_dim * (tid + 1)) / n_threads;
+    for (int r = 0; r < t->rows; r++) {
+        const float *xr = t->x + (size_t)r * t->in_dim;
+        float *yr = t->y + (size_t)r * t->out_dim;
+        for (int o = start; o < end; o++)
+            yr[o] = nemo_dot_f32(xr, t->w + (size_t)o * t->in_dim, t->in_dim)
+                    + (t->b ? t->b[o] : 0.0f);
+    }
+}
+
+static void nemo_f32_linear_ref(float *y, const float *x, const float *w,
+                                const float *b, int rows, int in_dim, int out_dim) {
+    nemo_f32_linear_task_t task = {y, x, w, b, rows, in_dim, out_dim};
+    long long work = (long long)rows * (long long)in_dim * (long long)out_dim;
+    if (g_tp.n_threads > 1 && work >= NEMO_PARALLEL_WORK_MIN) {
+        nemo_parallel_for(nemo_f32_linear_worker, &task);
+    } else {
+        nemo_f32_linear_worker(0, 1, &task);
+    }
+}
