+} nemo_f32_argmax_task_t;
+
+static void nemo_f32_argmax_worker(int tid, int n_threads, void *arg) {
+    nemo_f32_argmax_task_t *t = (nemo_f32_argmax_task_t *)arg;
+    int start = (t->out_dim * tid) / n_threads;
+    int end = (t->out_dim * (tid + 1)) / n_threads;
+    int best = start;
+    float best_val = -3.4028234663852886e38f;
+    for (int o = start; o < end; o++) {
+        float v = (t->b ? t->b[o] : 0.0f) +
