--- Makefile
+++ Makefile
@@ -45,7 +45,7 @@ TARGET = nemotron_asr$(EXE)
 SRCS = main.c nemotron_asr.c nemotron_asr_audio.c nemotron_asr_encoder.c nemotron_asr_decoder.c nemotron_asr_model.c nemotron_asr_kernels.c nemotron_asr_kernels_generic.c nemotron_asr_kernels_neon.c nemotron_asr_kernels_avx.c
 OBJS = $(SRCS:.c=.o)
 
-.PHONY: all clean debug generic
+.PHONY: all clean debug generic shared
 
 all: $(TARGET)
 
@@ -69,3 +69,14 @@ generic: clean $(TARGET)
 
 clean:
 	rm -f $(OBJS) $(TARGET)
+
+# ---- shared library (HA add-on) ----
+# Position-independent runtime objects (everything but the CLI main.o)
+# linked into libnemotron_asr.so; the Python add-on loads this at startup.
+SHARED_TARGET = libnemotron_asr.so
+RUNTIME_OBJS  = $(filter-out main.o,$(OBJS))
+shared: CFLAGS += -fPIC
+shared: $(SHARED_TARGET)
+
+$(SHARED_TARGET): $(RUNTIME_OBJS)
+	$(CC) $(CFLAGS) -shared -o $@ $(RUNTIME_OBJS) $(LDFLAGS)
